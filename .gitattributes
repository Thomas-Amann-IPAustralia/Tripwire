# Mark the SQLite database as binary so Git does not attempt text diffs or
# line-ending normalisation.  Upgrade to Git LFS if the file exceeds ~50 MB:
#   data/ipfr_corpus/ipfr.sqlite  filter=lfs diff=lfs merge=lfs -text
data/ipfr_corpus/ipfr.sqlite  binary

# Ensure consistent line endings for text files.
* text=auto
*.py text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.csv text eol=lf
*.md text eol=lf
